# .streamlit/secrets.toml.example
#
# Copy this file to .streamlit/secrets.toml and fill in your Google Drive file IDs.
# secrets.toml is in .gitignore — never commit it.
#
# How to get a Google Drive file ID:
#   1. Upload the file to Google Drive
#   2. Right-click → Share → "Anyone with the link"
#   3. Copy the link: https://drive.google.com/file/d/FILE_ID_HERE/view
#   4. Paste just the FILE_ID_HERE below

[drive]
# outputs/predictions.json  (~5.3 MB)
predictions_id = "PASTE_GOOGLE_DRIVE_FILE_ID_HERE"
